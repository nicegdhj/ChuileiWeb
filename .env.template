# ===== 访问配置 =====
# 对外暴露的端口，访问地址：http://<IP>:<WEB_PORT>/chuilei/chat
WEB_PORT=8088

# ===== 大模型配置（私域内网 LLM 地址）=====
# LLMClient 会自动拼接 /chat/completions，此处填 base url
LLM_BASE_URL=http://your-llm-server/v1
LLM_MODEL=your-model-name
LLM_MAX_TOKENS=32000
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=300

# ===== 后端 =====
BACKEND_LOG_LEVEL=INFO
